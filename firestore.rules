rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isRoot() {
      return request.auth != null && request.auth.token.email == 'melonoriaga@gmail.com';
    }

    function isSubAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isAnyAdmin() {
      return isRoot() || isSubAdmin();
    }

    // Leads: anyone can CREATE (public form).
    // Any admin can read and update.
    // Only root can delete.
    match /leads/{leadId} {
      allow create: if true;
      allow read, update: if isAnyAdmin();
      allow delete: if isRoot();
    }

    // Admins: any admin can read the list.
    // Root can write anything.
    // A newly authenticated user can create their own document (self-registration via invite).
    match /admins/{userId} {
      allow read: if isAnyAdmin();
      allow write: if isRoot();
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Invites: anyone can READ (to validate the token).
    // Root can create and delete.
    // An unauthenticated user can mark an unused invite as used
    // (only touching isUsed, usedAt, usedBy fields).
    match /invites/{inviteId} {
      allow read: if true;
      allow create, delete: if isRoot();
      allow update: if isRoot()
        || (
          resource.data.isUsed == false
          && request.resource.data.isUsed == true
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isUsed', 'usedAt', 'usedBy'])
        );
    }

    // Settings: anyone can read (for public-facing messages).
    // Only root can write.
    match /settings/{docId} {
      allow read: if true;
      allow write: if isRoot();
    }
  }
}
